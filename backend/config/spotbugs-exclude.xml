<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Ignore generated code -->
    <Match>
        <Class name="~.*\$\$.*"/>
    </Match>

    <!-- Ignore Lombok-generated equals/hashCode -->
    <Match>
        <Bug category="STYLE"/>
    </Match>

    <!-- Ignore Spring proxy classes -->
    <Match>
        <Class name="~.*Configuration.*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
